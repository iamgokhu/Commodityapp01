{
  "system": {
    "name": "CommodityOS",
    "version": "2.0.0",
    "log_level": "INFO"
  },
  "cycle": {
    "interval_seconds": 3600,
    "max_cycles": 0,
    "auto_publish": true
  },
  "products": [
    "Sugar", "Rice", "Grains", "Pulses", "Wheat", "Dals", "Basmathi Rice",
    "Oilseeds", "Spices", "Cotton", "Tea", "Coffee", "Rubber", "Coconut"
  ],
  "states": [
    "Maharashtra", "Uttar Pradesh", "Punjab", "Gujarat", "Rajasthan",
    "Madhya Pradesh", "Karnataka", "Tamil Nadu", "Andhra Pradesh", "West Bengal",
    "Bihar", "Odisha", "Telangana", "Kerala", "Haryana", "Assam", "Chhattisgarh"
  ],
  "countries": [
    "India", "USA", "China", "Brazil", "Thailand", "Vietnam", "Pakistan",
    "Indonesia", "Bangladesh", "Sri Lanka", "Nepal", "Myanmar", "UAE",
    "Saudi Arabia", "UK", "Germany", "Japan", "Singapore", "Malaysia", "Australia"
  ],
  "entity_types": ["Manufacturer", "Wholesaler", "Exporter", "Online Seller", "Government Source", "News Reference"],
  "crawlers": {
    "indiamart": { "enabled": true, "max_retries": 3, "rate_limit_per_minute": 25, "products": ["Sugar","Rice","Wheat","Pulses","Grains"] },
    "tradeindia": { "enabled": true, "max_retries": 3, "rate_limit_per_minute": 20, "products": ["Pulses","Grains","Dals","Oilseeds"] },
    "agmarknet": { "enabled": true, "max_retries": 3, "rate_limit_per_minute": 15, "products": ["All Commodities"] },
    "apmc": { "enabled": true, "max_retries": 2, "rate_limit_per_minute": 10, "products": ["Regional Markets"] },
    "export_directory": { "enabled": true, "max_retries": 2, "rate_limit_per_minute": 12, "products": ["Export Data"] },
    "amazon_business": { "enabled": true, "max_retries": 3, "rate_limit_per_minute": 20, "products": ["All Commodities"], "platform": "amazon.in/business" },
    "flipkart_wholesale": { "enabled": true, "max_retries": 3, "rate_limit_per_minute": 18, "products": ["All Commodities"], "platform": "flipkart.com/wholesale" },
    "government_api": { "enabled": true, "max_retries": 2, "rate_limit_per_minute": 10, "products": ["Official Data"], "portals": ["data.gov.in","agmarknet.gov.in","eproc.gov.in"] },
    "linkedin": { "enabled": true, "max_retries": 2, "rate_limit_per_minute": 8, "products": ["Company Profiles"], "platform": "linkedin.com" },
    "news": { "enabled": true, "max_retries": 2, "rate_limit_per_minute": 15, "products": ["Market News"], "sources": ["Economic Times","Business Standard","Reuters India"] }
  },
  "pipeline": {
    "dedup_similarity_threshold": 0.85,
    "max_batch_size": 1000,
    "validation_strict": false
  },
  "github": {
    "auto_commit": true,
    "auto_push": true,
    "pages_enabled": true,
    "commit_message_prefix": "[auto]"
  },
  "monitoring": {
    "health_check_interval": 60,
    "checkpoint_enabled": true,
    "checkpoint_path": "data/checkpoint.json"
  }
}
